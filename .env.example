# Bu dosya bir ŞABLON'dur. Gerçek değerleri .env dosyasına yazın.
# .env DOSYASI ASLA git'e commit EDİLMEZ — .gitignore'da olmalı.

# ── UDP Güvenliği ─────────────────────────────────────────────────

# UDP payload'larını imzalamak için kullanılan paylaşımlı sır.
# Üretmek için: python -c "import secrets; print(secrets.token_urlsafe(32))"
IOT_HMAC_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# ── Flask API Güvenliği ───────────────────────────────────────────

# Flask API'yi çağırırken (udp_bridge → app) gerekli header.
# Üretmek için: python -c "import secrets; print(secrets.token_urlsafe(24))"
IOT_API_KEY=change_me_to_a_random_api_key

# ── readings.json Şifreleme (Opsiyonel) ──────────────────────────

# true = readings.json Fernet (AES-128-CBC) ile şifrelenir
# false = düz JSON (varsayılan, geliştirme için yeterli)
READINGS_ENCRYPT=false

# Fernet şifreleme anahtarı (READINGS_ENCRYPT=true ise zorunlu)
# Üretmek için:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# UYARI: Bu anahtarı kaybedersen verileri kurtaramazsın!
READINGS_ENCRYPT_KEY=change_me_to_a_fernet_key_generated_with_command_above

# ── Grafana / Docker ──────────────────────────────────────────────

# Grafana admin kullanıcı adı (varsayılan "admin" kullanmayın)
GRAFANA_ADMIN_USER=change_me_admin_username

# Grafana admin şifresi (en az 12 karakter, büyük/küçük harf + rakam)
GRAFANA_ADMIN_PASSWORD=change_me_to_strong_password_12chars_min
